   }
@@ -1144,7 +1169,7 @@ set_add_all(mrb_state *mrb, mrb_value self)
 
   int ai = mrb_gc_arena_save(mrb);
   for (mrb_int i = 0; i < argc; i++) {
-    kset_put(mrb, set, argv[i]);
+    set_put_value(mrb, set, argv[i], NULL);
     mrb_gc_arena_restore(mrb, ai);
   }
 
@@ -1199,7 +1224,7 @@ set_flatten_recursive(mrb_state *mrb, kset_t *target, kset_t *source, int *seen_
     }
     else {
       /* Add non-Set element directly */
-      kset_put(mrb, target, elem);
+      set_put_value(mrb, target, elem, NULL);
     }
     mrb_gc_arena_restore(mrb, ai);
   }
@@ -1410,7 +1435,7 @@ set_s_create(mrb_state *mrb, mrb_value klass)
   kset_t *ks = set_get_kset(mrb, set);
 
   for (mrb_int i = 0; i < argc; i++) {
-    kset_put(mrb, ks, argv[i]);
+    set_put_value(mrb, ks, argv[i], NULL);
